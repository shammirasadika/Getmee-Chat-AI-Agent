# ===== Chroma Configuration =====

# Modes:  http / cloud
CHROMA_MODE=cloud


# --- HTTP mode (self-hosted:  VM / Docker) ---
CHROMA_HOST=YOUR_CHROMA_VM_IP  # e.g. 10.0.0.5 or public IP
CHROMA_PORT=8000

# --- ChromaDB (cloud mode: Chroma Cloud) ---
# Set CHROMA_MODE=cloud to use these
CHROMA_HOST=api.trychroma.com
CHROMA_API_KEY=ck-9GMPjLr5NJd24my6H9z94S5Q8qKUpbns6cMW2FZ1t7wg
CHROMA_TENANT=9b2b247c-d3bb-4511-86c3-b77a4113355f
CHROMA_DATABASE=getmee_dev
CHROMA_URL=https://api.trychroma.com

# --- Common setting---
CHROMA_COLLECTION=getmee_docs_dev
## For local/dev, use 8001. For Render/cloud, set to $PORT (Render injects this env variable)
INGESTION_PORT=$PORT
TEMP_DIR=/tmp