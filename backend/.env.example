# ChromaDB settings (match ingestion pipeline)
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=getmee_docs_dev
CHROMA_PATH=../ingestion_pipeline/chroma-data
TEMP_DIR=./tmp
# Groq LLM Provider
GROQ_API_KEY=your-groq-api-key-here
# ---
# Neon/PostgreSQL connection options (for advanced use cases):
# DATABASE_URL=postgresql://neondb_owner:...@.../neondb?channel_binding=require&sslmode=require
# DATABASE_URL_UNPOOLED=postgresql://neondb_owner:...@.../neondb?sslmode=require
# PGHOST=...
# PGHOST_UNPOOLED=...
# PGUSER=neondb_owner
# PGDATABASE=neondb
# PGPASSWORD=...
# POSTGRES_URL=postgresql://neondb_owner:...@.../neondb?channel_binding=require&sslmode=require
# POSTGRES_URL_NON_POOLING=postgresql://neondb_owner:...@.../neondb?channel_binding=require&sslmode=require
# POSTGRES_USER=neondb_owner
# POSTGRES_HOST=...
# POSTGRES_PASSWORD=...
# POSTGRES_DATABASE=neondb
# POSTGRES_URL_NO_SSL=postgresql://neondb_owner:...@.../neondb
# POSTGRES_PRISMA_URL=postgresql://neondb_owner:...@.../neondb?channel_binding=require&connect_timeout=15&sslmode=require
#
# For most backend uses, set only POSTGRES_URL below:

# ChromaDB (local path for now)
CHROMA_PATH=../ingestion_pipeline/chroma-data

# Redis (Upstash recommended)
REDIS_URL=your_upstash_redis_connection_string

# PostgreSQL (Neon recommended)
POSTGRES_URL=postgresql://neondb_owner:npg_OuSTsr36ahJZ@ep-fancy-butterfly-a7x13cta-pooler.ap-southeast-2.aws.neon.tech/neondb?channel_binding=require&sslmode=require

# LLM Provider (only "groq" is supported)
LLM_PROVIDER=groq
LLM_API_KEY=your_groq_api_key_here

# Logging
LOG_LEVEL=INFO

# Email (for FastAPI-Mail or SMTP)
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_email_password_or_app_password
MAIL_FROM=your_email@gmail.com
MAIL_PORT=587
MAIL_SERVER=smtp.gmail.com
MAIL_TLS=True
MAIL_SSL=False
